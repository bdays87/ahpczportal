<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Registration Certificate</title>
    <style>
        @page { size: A4 landscape; margin: 0; }
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Times New Roman', Times, serif;
            width: 297mm;
            height: 210mm;
            background: #fff;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .page {
            width: 297mm;
            height: 210mm;
            position: relative;
        }

        /* Single checkerboard border — no doubles */
        .b-pattern {
            position: absolute;
            top: 4mm; left: 4mm; right: 4mm; bottom: 4mm;
            border: 4px solid #111;
            background-image: repeating-conic-gradient(#111 0% 25%, #fff 0% 50%);
            background-size: 5px 5px;
        }
        .b-inner-fill {
            position: absolute;
            top: 12mm; left: 12mm; right: 12mm; bottom: 12mm;
            background: #fff;
            border: 2px solid #111;
        }

        /* Crest box centered on top border */
        .crest-wrap {
            position: absolute;
            top: 5mm;
            left: 50%;
            margin-left: -18mm;
            width: 36mm;
            z-index: 10;
            background: #fff;
            border: 2px solid #111;
            padding: 2px;
            text-align: center;
        }
        .crest-wrap img {
            width: 32mm;
            height: 32mm;
            object-fit: contain;
            display: block;
        }

        /* Outer wrapper table fills the inner area */
        .outer-table {
            position: absolute;
            top: 14mm; left: 14mm; right: 14mm; bottom: 14mm;
            width: calc(297mm - 28mm);
            height: calc(210mm - 28mm);
            border-collapse: collapse;
        }

        /* Top cell: all certificate content */
        .td-body {
            vertical-align: top;
            padding: 14mm 6mm 4mm 6mm;
            text-align: center;
        }

        .no-line {
            text-align: left;
            font-size: 8pt;
            font-weight: bold;
            margin-bottom: 3mm;
        }
        .no-line span {
            display: inline-block;
            border-bottom: 1px solid #111;
            min-width: 35mm;
            margin-left: 2mm;
        }

        .h-country {
            font-size: 20pt;
            font-weight: bold;
            letter-spacing: 4px;
            text-transform: uppercase;
        }
        .h-council { font-size: 10pt; margin-top: 2px; }
        .h-reg-cert {
            font-size: 13pt;
            font-weight: bold;
            text-transform: uppercase;
            margin-top: 3px;
        }
        .h-certify { font-size: 13pt; font-weight: bold; margin-top: 2px; }

        .hr { border: none; border-top: 1px solid #111; margin: 3mm 0; }

        .name-row {
            font-size: 14pt;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 2mm 0;
        }
        .reg-of { font-size: 10pt; margin: 2mm 0; }
        .profession-row {
            font-size: 13pt;
            font-weight: bold;
            text-transform: uppercase;
            margin: 2mm 0;
        }
        .legal-para {
            font-size: 11pt;
            line-height: 1.7;
            margin: 3mm 0;
        }

        /* Bottom footer cell */
        .td-footer {
            vertical-align: bottom;
            padding: 0 6mm 4mm 6mm;
            height: 30mm;
        }

        .footer-table {
            width: 100%;
            border-collapse: collapse;
        }
        .footer-table td { vertical-align: bottom; padding: 0; }

        .td-date { width: 50%; vertical-align: bottom; }
        .td-sig  { width: 50%; text-align: right; vertical-align: bottom; }

        .date-block { font-size: 8pt; font-weight: bold; }
        .date-block span {
            display: inline-block;
            border-bottom: 1px solid #111;
            min-width: 40mm;
            margin-left: 2mm;
        }

        .qr-img {
            width: 25mm;
            height: 25mm;
            object-fit: contain;
            display: block;
            margin: 0 auto;
        }

        .sig-img {
            width: 45mm;
            height: 18mm;
            object-fit: contain;
            display: block;
            margin-left: auto;
        }
        .sig-line {
            border-top: 1px solid #111;
            padding-top: 2px;
            text-align: right;
        }
        .sig-label {
            font-size: 7pt;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .sig-council { font-size: 6pt; text-transform: uppercase; }
    </style>
</head>
<body>
<div class="page">

    <div class="b-pattern"></div>
    <div class="b-inner-fill"></div>

    <div class="crest-wrap">
        <img src="./imgs/crest.png" alt="Crest">
    </div>

    {{-- Two-row table: body content top, footer pinned bottom --}}
    <table class="outer-table">
        <tr>
            <td class="td-body">
                <div class="no-line">NO.<span>{{ $data->customerprofession->customer->regnumber }}</span></div>

                <div class="h-country">Zimbabwe</div>
                <div class="h-council">{{ config('app.title') }}</div>
                <div class="h-reg-cert">Registration Certificate</div>
                <div class="h-certify">This is to Certify That</div>

                <hr class="hr">

                <div class="name-row">
                    {{ strtoupper($data->customerprofession->customer->name . ' ' . $data->customerprofession->customer->surname) }}
                </div>

                <div class="reg-of">is registered on the register of</div>

                <hr class="hr">

                <div class="profession-row">
                    {{ strtoupper($data->customerprofession->profession->name) }}
                </div>

                <hr class="hr">

                <div class="legal-para">
                    kept by the {{ config('app.title') }}<br>
                    in accordance with the provisions of the Health Professions Act, CAP 27:19
                </div>
            </td>
        </tr>
        <tr>
            <td class="td-footer">
                <table class="footer-table">
                    <tr>
                        <td class="td-date">
                            <div class="date-block">
                                DATE<span>{{ \Carbon\Carbon::parse($data->registrationdate)->format('d F Y') }}</span>
                            </div>
                            <img class="qr-img" src="{{ $qrcode }}" alt="QR Code" style="margin-top:3mm;">
                        </td>
                        <td class="td-sig">
                            <img class="sig-img" src="./imgs/signature.png" alt="Signature">
                            <div class="sig-line">
                                <div class="sig-label">Registrar</div>
                                <div class="sig-council">{{ config('app.title') }}</div>
                            </div>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

</div>
</body>
</html>
